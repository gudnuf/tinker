# Auto-generated by Tinker for round: {name}
# Copy this template, replace {name} and {port}, adjust ExecStart for your stack.
#
# Server app template (Node.js, Python, etc.)
# For static sites, use the static template at the bottom.
{ config, pkgs, lib, ... }:
{
  systemd.services."tinker-{name}" = {
    description = "Tinker app: {name}";
    after = [ "network.target" ];
    wantedBy = [ "multi-user.target" ];

    serviceConfig = {
      Type = "simple";
      DynamicUser = true;
      WorkingDirectory = "/srv/tinker/projects/{name}";
      ExecStart = "${pkgs.nodejs}/bin/node server.js";
      Restart = "on-failure";
      RestartSec = 5;

      # Sandboxing
      ProtectSystem = "strict";
      ProtectHome = "read-only";
      ReadWritePaths = [ "/srv/tinker/projects/{name}" ];
      PrivateTmp = true;
      NoNewPrivileges = true;

      # Resource limits
      MemoryMax = "256M";
      CPUQuota = "50%";

      Environment = [
        "PORT={port}"
        "NODE_ENV=production"
      ];
    };
  };

  # Caddy reverse proxy — auto-provisions TLS
  services.caddy.virtualHosts."{name}.tinker.builders" = {
    extraConfig = ''
      reverse_proxy localhost:{port}
    '';
  };
}

# --- Static site alternative (no systemd service needed) ---
