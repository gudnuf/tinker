# modules/apps/{name}.nix — auto-generated by tinker bot
# port: {port} | domain: {name}.tinker.builders
{ config, pkgs, lib, ... }:
{
  # App service
  systemd.services."tinker-{name}" = {
    description = "Tinker app: {name}";
    after = [ "network.target" ];
    wantedBy = [ "multi-user.target" ];

    serviceConfig = {
      Type = "simple";
      ExecStart = "${pkgs.nodejs}/bin/node server.js";
      WorkingDirectory = "/home/openclaw/projects/{name}";
      User = "openclaw";
      Restart = "on-failure";
      RestartSec = 5;

      # Sandboxing
      ProtectSystem = "strict";
      ProtectHome = "read-only";
      ReadWritePaths = [ "/home/openclaw/projects/{name}" ];
      PrivateTmp = true;
      NoNewPrivileges = true;

      # Resource limits
      MemoryMax = "256M";
      CPUQuota = "50%";

      # Environment
      Environment = [
        "PORT={port}"
        "NODE_ENV=production"
      ];
    };
  };

  # Caddy reverse proxy — on-demand TLS handles certs automatically
  services.caddy.virtualHosts."{name}.tinker.builders" = {
    extraConfig = ''
      tls {
        on_demand
      }
      reverse_proxy localhost:{port}
    '';
  };
}
