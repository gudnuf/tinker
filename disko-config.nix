# disko-config.nix — declarative disk layout for Hetzner VPS
#
# Used by nixos-anywhere during provisioning. Defines:
# - GPT partition table
# - 512MB EFI system partition (fat32, mounted at /boot)
# - Remainder as ext4 root partition (mounted at /)
{
  disko.devices = {
    disk = {
      main = {
        type = "disk";
        device = "/dev/sda";
        content = {
          type = "gpt";
          partitions = {
            ESP = {
              size = "512M";
              type = "EF00";
              content = {
                type = "filesystem";
                format = "vfat";
                mountpoint = "/boot";
                mountOptions = [ "umask=0077" ];
              };
            };
            root = {
              size = "100%";
              content = {
                type = "filesystem";
                format = "ext4";
                mountpoint = "/";
              };
            };
          };
        };
      };
    };
  };
}
